# Generate a random secret: https://generate-secret.vercel.app/32 or `openssl rand -base64 32`
AUTH_SECRET=****

# The following keys below are automatically created and
# added to your environment when you deploy on Vercel

# Instructions to create an AI Gateway API key here: https://vercel.com/ai-gateway 
# API key required for non-Vercel deployments
# For Vercel deployments, OIDC tokens are used automatically
# https://vercel.com/ai-gateway
AI_GATEWAY_API_KEY=****


# Instructions to create a Vercel Blob Store here: https://vercel.com/docs/vercel-blob
BLOB_READ_WRITE_TOKEN=****

# LLM backend selection:
# - openrouter: route all model traffic through OpenRouter
# - gateway: keep using the legacy Vercel AI Gateway path
LLM_BACKEND=openrouter

# OpenRouter API key for the default backend path
OPENROUTER_API_KEY=****

# Backend-owned model aliases. The chat UI uses the "auto" alias and the server
# resolves it to these model ids.
OPENROUTER_CHAT_MODEL=google/gemini-2.5-flash-lite
OPENROUTER_TITLE_MODEL=google/gemini-2.5-flash-lite
OPENROUTER_ARTIFACT_MODEL=anthropic/claude-haiku-4.5
OPENROUTER_REASONING_MODEL=anthropic/claude-3.7-sonnet:thinking

# Optional OpenRouter routing controls
# OPENROUTER_PROVIDER_ORDER=google-vertex,deepseek
# OPENROUTER_PROVIDER_ONLY=google-vertex
# OPENROUTER_PROVIDER_IGNORE=some-provider
# OPENROUTER_PROVIDER_ALLOW_FALLBACKS=true
# OPENROUTER_PROVIDER_REQUIRE_PARAMETERS=true
# OPENROUTER_PROVIDER_DATA_COLLECTION=deny
# OPENROUTER_PROVIDER_SORT=price
#
# Optional provider API key injection for OpenRouter provider routing.
# Format: provider-slug=api-key,provider-slug-2=api-key-2
# Examples: google-vertex=<key>,deepseek=<key>,google=<key>
# OPENROUTER_PROVIDER_API_KEYS=google-vertex=****,deepseek=****

# Instructions to create a PostgreSQL database here: https://vercel.com/docs/postgres
POSTGRES_URL=****


# Instructions to create a Redis store here:
# https://vercel.com/docs/redis
REDIS_URL=****
